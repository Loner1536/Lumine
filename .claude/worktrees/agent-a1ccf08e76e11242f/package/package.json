{
    "name": "lumine",
    "version": "0.1.0",
    "description": "Luau type annotation tool for compiled roblox-ts / rotor projects",
    "type": "module",
    "bin": {
        "lumine": "./src/index.ts"
    },
    "scripts": {
        "build": "bun build src/index.ts --compile --outfile dist/lumine",
        "watch": "bun build src/index.ts --outdir dist --watch"
    },
    "dependencies": {
        "typescript": "^5.8.3"
    }
}
