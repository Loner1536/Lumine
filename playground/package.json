{
	"name": "playground",
	"scripts": {
		"build": "rojo build -o ./playground.rbxlx",
		"watch": "rbxtsc -p ./src -i ./out/include -w",
		"compile": "rm -rf ./out && rbxtsc -p ./src -i ./out/include",
		"dev": "concurrently \"rojo serve default.project.json --address 0.0.0.0 \" \"rbxtsc -p ./src -i ./out/include -w\""
	},
	"dependencies": {
		"@flamework/components": "^1.3.2",
		"@flamework/core": "^1.3.2",
		"@flamework/networking": "^1.3.2",
		"@rbxts/charm": "^0.10.0",
		"@rbxts/lync": "github:Loner1536/lync#main",
		"@rbxts/object-utils": "^1.0.4",
		"@rbxts/react": "^17.3.7-alpha.1",
		"@rbxts/react-charm": "^0.3.0",
		"@rbxts/react-roblox": "^17.3.7-alpha.1",
		"@rbxts/ripple": "^0.10.2",
		"@rbxts/services": "^1.6.0",
		"@rbxts/set-timeout": "^1.1.2",
		"@rbxts/signal": "^1.1.1",
		"@rbxts/typenet": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.2",
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@rbxts/types": "^1.0.908",
		"@rbxts/ui-labs": "^2.4.2",
		"@types/node": "^24.10.13",
		"concurrently": "^9.2.1",
		"patch-package": "^8.0.1",
		"postinstall-postinstall": "^2.1.0",
		"rbxts-transform-env": "^3.0.0",
		"rbxts-transformer-flamework": "^1.3.2",
		"roblox-ts": "^3.0.0",
		"tsx": "^4.21.0",
		"turbo": "^2.8.10",
		"typescript": "=5.5.3"
	}
}
