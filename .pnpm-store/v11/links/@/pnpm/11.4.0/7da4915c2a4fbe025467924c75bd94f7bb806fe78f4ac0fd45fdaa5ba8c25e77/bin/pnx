#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
fi
# cmd-shim-target=/workspaces/Typenet/.pnpm-store/v11/links/@/pnpm/11.4.0/7da4915c2a4fbe025467924c75bd94f7bb806fe78f4ac0fd45fdaa5ba8c25e77/node_modules/pnpm/bin/pnpx.mjs
