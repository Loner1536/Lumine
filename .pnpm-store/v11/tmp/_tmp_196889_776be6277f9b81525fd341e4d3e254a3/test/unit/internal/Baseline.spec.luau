--!strict
--!optimize 2
-- internal.Baseline: per-key delta cache plus hasDelta flag.

local Env = require(script:FindFirstAncestor("test").Env)

local Baseline = Env.Internal.Baseline
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

describe("internal.Baseline", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("default state", function(): ()
        it("hasDelta starts false", function(): ()
            expect(Baseline.hasDelta()):toBe(false)
        end)
        it("getCache returns nil with no caches set", function(): ()
            expect(Baseline.getCache(1)):toBeNil()
        end)
    end)

    describe("get / set cache under current read key", function(): ()
        it("set then get returns the value", function(): ()
            Baseline.setReadKey(false)
            Baseline.setCache(101, { hp = 100 })
            local cached = Baseline.getCache(101)
            expect((cached :: any).hp):toBe(100)
        end)
        it("overwriting replaces value", function(): ()
            Baseline.setReadKey(false)
            Baseline.setCache(202, "old")
            Baseline.setCache(202, "new")
            expect(Baseline.getCache(202)):toBe("new")
        end)
        it("cache is empty for an untouched delta ID", function(): ()
            Baseline.setReadKey(false)
            Baseline.setCache(303, "a")
            expect(Baseline.getCache(404)):toBeNil()
        end)
    end)

    describe("per-key isolation", function(): ()
        it("different keys are independent", function(): ()
            local a = Instance.new("Folder")
            local b = Instance.new("Folder")
            Baseline.setReadKey(a)
            Baseline.setCache(1, "A")
            Baseline.setReadKey(b)
            Baseline.setCache(1, "B")
            Baseline.setReadKey(a)
            expect(Baseline.getCache(1)):toBe("A")
            Baseline.setReadKey(b)
            expect(Baseline.getCache(1)):toBe("B")
            a:Destroy()
            b:Destroy()
        end)
        it("a key cannot see another key's data", function(): ()
            local a = Instance.new("Folder")
            local b = Instance.new("Folder")
            Baseline.setReadKey(a)
            Baseline.setCache(1, "A")
            Baseline.setReadKey(b)
            expect(Baseline.getCache(1)):toBeNil()
            a:Destroy()
            b:Destroy()
        end)
        it("`false` and an Instance key are distinct", function(): ()
            local inst = Instance.new("Folder")
            Baseline.setReadKey(false)
            Baseline.setCache(7, "client")
            Baseline.setReadKey(inst)
            expect(Baseline.getCache(7)):toBeNil()
            inst:Destroy()
        end)
    end)

    describe("clearPlayer", function(): ()
        it("removes only the targeted key's caches", function(): ()
            local a = Instance.new("Folder")
            local b = Instance.new("Folder")
            Baseline.setReadKey(a)
            Baseline.setCache(1, "A")
            Baseline.setCache(2, "A2")
            Baseline.setReadKey(b)
            Baseline.setCache(1, "B")
            Baseline.clearPlayer(a)
            Baseline.setReadKey(a)
            expect(Baseline.getCache(1)):toBeNil()
            expect(Baseline.getCache(2)):toBeNil()
            Baseline.setReadKey(b)
            expect(Baseline.getCache(1)):toBe("B")
            a:Destroy()
            b:Destroy()
        end)
    end)

    describe("hasDelta latch", function(): ()
        it("markHasDelta flips it true", function(): ()
            expect(Baseline.hasDelta()):toBe(false)
            Baseline.markHasDelta()
            expect(Baseline.hasDelta()):toBe(true)
        end)
        it("Sandbox reset clears the flag", function(): ()
            Baseline.markHasDelta()
            expect(Baseline.hasDelta()):toBe(true)
            Sandbox.resetAll()
            expect(Baseline.hasDelta()):toBe(false)
        end)
        it("idempotent: marking twice keeps it true", function(): ()
            Baseline.markHasDelta()
            Baseline.markHasDelta()
            expect(Baseline.hasDelta()):toBe(true)
        end)
    end)

    describe("multi-key, multi-id stress", function(): ()
        it("100 deltaIds across one key isolated correctly", function(): ()
            Baseline.setReadKey(false)
            for i = 1, 100 do
                Baseline.setCache(i, `value_{i}`)
            end
            for i = 1, 100 do
                expect(Baseline.getCache(i)):toBe(`value_{i}`)
            end
        end)
        it("setReadKey switching keeps each key's caches independent", function(): ()
            local k1 = Instance.new("Folder")
            local k2 = Instance.new("Folder")
            local k3 = Instance.new("Folder")
            Baseline.setReadKey(k1)
            Baseline.setCache(1, "k1")
            Baseline.setReadKey(k2)
            Baseline.setCache(1, "k2")
            Baseline.setReadKey(k3)
            Baseline.setCache(1, "k3")
            Baseline.setReadKey(k1)
            expect(Baseline.getCache(1)):toBe("k1")
            Baseline.setReadKey(k2)
            expect(Baseline.getCache(1)):toBe("k2")
            Baseline.setReadKey(k3)
            expect(Baseline.getCache(1)):toBe("k3")
            k1:Destroy()
            k2:Destroy()
            k3:Destroy()
        end)
        it("clearPlayer with no caches is a no-op", function(): ()
            local k = Instance.new("Folder")
            expect(function(): ()
                Baseline.clearPlayer(k)
            end).never:toThrow()
            k:Destroy()
        end)
    end)

    describe("cache value types", function(): ()
        it("can hold a buffer", function(): ()
            Baseline.setReadKey(false)
            local b = buffer.create(4)
            buffer.writeu32(b, 0, 0xABCDEF12)
            Baseline.setCache(1, b)
            local cached = Baseline.getCache(1) :: buffer
            expect(buffer.readu32(cached, 0)):toBe(0xABCDEF12)
        end)
        it("can hold nested tables", function(): ()
            Baseline.setReadKey(false)
            Baseline.setCache(1, { a = { b = { c = 42 } } })
            local cached = Baseline.getCache(1) :: any
            expect(cached.a.b.c):toBe(42)
        end)
        it("setCache with nil clears the entry", function(): ()
            Baseline.setReadKey(false)
            Baseline.setCache(1, "x")
            Baseline.setCache(1, nil)
            expect(Baseline.getCache(1)):toBeNil()
        end)
    end)

    describe("reset semantics", function(): ()
        it("Baseline.reset clears all keys, all ids", function(): ()
            local a = Instance.new("Folder")
            Baseline.setReadKey(a)
            Baseline.setCache(1, "x")
            Baseline.setReadKey(false)
            Baseline.setCache(1, "y")
            Baseline.reset()
            Baseline.setReadKey(a)
            expect(Baseline.getCache(1)):toBeNil()
            Baseline.setReadKey(false)
            expect(Baseline.getCache(1)):toBeNil()
            a:Destroy()
        end)
        it("reset clears hasDelta latch", function(): ()
            Baseline.markHasDelta()
            Baseline.reset()
            expect(Baseline.hasDelta()):toBe(false)
        end)
    end)
end)

return nil
