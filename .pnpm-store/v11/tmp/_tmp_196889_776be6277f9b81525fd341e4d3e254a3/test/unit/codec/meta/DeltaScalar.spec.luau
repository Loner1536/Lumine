--!strict
--!optimize 2
-- Lync.deltaInt / deltaFloat / deltaVec3 / deltaCFrame: per-frame diff codecs.

local Env = require(script:FindFirstAncestor("test").Env)

local Baseline = Env.Internal.Baseline
local InternalChannel = Env.Internal.Channel
local Lync = Env.Lync
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

-- Drive write→read against the same (write channel, baseline key) pair.
local function roundTripDelta(codec: any, ch: any, value: any): any
    local startCursor = ch.cursor
    codec.write(ch, value)
    local payload = buffer.create(ch.cursor - startCursor)
    if ch.cursor - startCursor > 0 then
        buffer.copy(payload, 0, ch.buff, startCursor, ch.cursor - startCursor)
    end
    local decoded = codec.read(payload, 0, nil)
    return decoded
end

describe("codec.meta.DeltaScalar", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("deltaInt", function(): ()
        describe("metadata", function(): ()
            it("flags _isDelta", function(): ()
                expect((Lync.deltaInt(0, 1000) :: any)._isDelta):toBe(true)
            end)
            it("flags _isInteger", function(): ()
                expect((Lync.deltaInt(0, 1000) :: any)._isInteger):toBe(true)
            end)
            it("records min/max", function(): ()
                local c = Lync.deltaInt(-50, 100) :: any
                expect(c._min):toBe(-50)
                expect(c._max):toBe(100)
            end)
        end)

        describe("wire size", function(): ()
            it("first frame at min: 1 byte (zigzag of 0)", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                c.write(ch, 0)
                expect(ch.cursor):toBe(1)
            end)
            it("unchanged from prev: 1 byte", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                c.write(ch, 100)
                ch.cursor = 0
                c.write(ch, 100)
                expect(ch.cursor):toBe(1)
            end)
            it("small diff (+1): 1 byte", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                c.write(ch, 100)
                ch.cursor = 0
                c.write(ch, 101)
                expect(ch.cursor):toBe(1)
            end)
            it("medium diff (+500): 2 bytes", function(): ()
                local c = Lync.deltaInt(0, 100000)
                local ch = InternalChannel.create()
                c.write(ch, 0)
                ch.cursor = 0
                c.write(ch, 500)
                expect(ch.cursor):toBe(2)
            end)
        end)

        describe("round-trip", function(): ()
            it("first frame decodes correctly", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                expect(roundTripDelta(c, ch, 100)):toBe(100)
            end)
            it("incremental sequence preserves values", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                local sequence = { 100, 105, 110, 115, 120 }
                for _, v in sequence do
                    expect(roundTripDelta(c, ch, v)):toBe(v)
                end
            end)
            it("negative diff decodes correctly", function(): ()
                local c = Lync.deltaInt(0, 1000)
                local ch = InternalChannel.create()
                roundTripDelta(c, ch, 500)
                expect(roundTripDelta(c, ch, 400)):toBe(400)
            end)
        end)

        describe("bounds checks", function(): ()
            it("write below min throws", function(): ()
                local c = Lync.deltaInt(0, 100)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, -1)
                end):toThrow("out of range")
            end)
            it("write above max throws", function(): ()
                local c = Lync.deltaInt(0, 100)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, 101)
                end):toThrow("out of range")
            end)
            it("non-integer write throws", function(): ()
                local c = Lync.deltaInt(0, 100)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, 50.5)
                end):toThrow("integer")
            end)
        end)

        describe("define-time errors", function(): ()
            it("min > max throws", function(): ()
                expect(function(): ()
                    Lync.deltaInt(10, 5)
                end):toThrow("must be <=")
            end)
            it("non-integer bounds throw", function(): ()
                expect(function(): ()
                    Lync.deltaInt(0.5, 10)
                end):toThrow("integers")
            end)
        end)
    end)

    describe("deltaFloat", function(): ()
        describe("wire size", function(): ()
            it("unchanged float: 1 byte", function(): ()
                local c = Lync.deltaFloat(0, 100, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, 50.5)
                ch.cursor = 0
                c.write(ch, 50.5)
                expect(ch.cursor):toBe(1)
            end)
            it("small diff: 1-2 bytes", function(): ()
                local c = Lync.deltaFloat(0, 100, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, 50.5)
                ch.cursor = 0
                c.write(ch, 50.51)
                expect(ch.cursor):toBeLessThan(3)
            end)
        end)

        describe("round-trip", function(): ()
            it("first frame decodes within precision", function(): ()
                local c = Lync.deltaFloat(0, 100, 0.01)
                local ch = InternalChannel.create()
                local r = roundTripDelta(c, ch, 50.5)
                expect(math.abs(r - 50.5) < 0.02):toBe(true)
            end)
            it("incremental motion preserves values within precision", function(): ()
                local c = Lync.deltaFloat(0, 100, 0.01)
                local ch = InternalChannel.create()
                roundTripDelta(c, ch, 50.0)
                local r = roundTripDelta(c, ch, 50.5)
                expect(math.abs(r - 50.5) < 0.02):toBe(true)
            end)
        end)

        describe("degenerate range", function(): ()
            it("min == max yields a 0-byte constant codec", function(): ()
                local c = Lync.deltaFloat(7, 7, 0.01) :: any
                expect(c._size):toBe(0)
            end)
        end)
    end)

    describe("deltaVec3", function(): ()
        describe("wire size", function(): ()
            it("first frame at min: 3 bytes (three zero zigzags)", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, Vector3.new(0, 0, 0))
                expect(ch.cursor):toBe(3)
            end)
            it("unchanged: 3 bytes", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, Vector3.new(50, 50, 50))
                ch.cursor = 0
                c.write(ch, Vector3.new(50, 50, 50))
                expect(ch.cursor):toBe(3)
            end)
            it("small motion (~0.01 per axis): still 3 bytes", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, Vector3.new(50, 50, 50))
                ch.cursor = 0
                c.write(ch, Vector3.new(50.01, 50.01, 50.01))
                expect(ch.cursor):toBe(3)
            end)
        end)

        describe("round-trip", function(): ()
            it("first frame decodes within precision", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                local r = roundTripDelta(c, ch, Vector3.new(50, 60, 70))
                expect(math.abs(r.X - 50) < 0.02):toBe(true)
                expect(math.abs(r.Y - 60) < 0.02):toBe(true)
                expect(math.abs(r.Z - 70) < 0.02):toBe(true)
            end)
            it("motion preserves quantized values across frames", function(): ()
                local c = Lync.deltaVec3(-100, 100, 0.01)
                local ch = InternalChannel.create()
                roundTripDelta(c, ch, Vector3.new(0, 0, 0))
                local r = roundTripDelta(c, ch, Vector3.new(1.5, -2.5, 3.0))
                expect(math.abs(r.X - 1.5) < 0.02):toBe(true)
                expect(math.abs(r.Y - -2.5) < 0.02):toBe(true)
                expect(math.abs(r.Z - 3.0) < 0.02):toBe(true)
            end)
        end)

        describe("range validation", function(): ()
            it("X above max throws", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, Vector3.new(101, 50, 50))
                end):toThrow("out of range")
            end)
            it("Y below min throws", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, Vector3.new(50, -1, 50))
                end):toThrow("out of range")
            end)
            it("Z above max throws", function(): ()
                local c = Lync.deltaVec3(0, 100, 0.01)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, Vector3.new(50, 50, 1000))
                end):toThrow("out of range")
            end)
        end)
    end)

    describe("deltaCFrame", function(): ()
        describe("wire size", function(): ()
            it("static CFrame after first frame: 1 byte (header only)", function(): ()
                local c = Lync.deltaCFrame(-1000, 1000, 0.01)
                local ch = InternalChannel.create()
                local cf = CFrame.new(10, 20, 30)
                c.write(ch, cf)
                ch.cursor = 0
                c.write(ch, cf)
                expect(ch.cursor):toBe(1)
            end)
            it("position-only motion: 1 + position varints", function(): ()
                local c = Lync.deltaCFrame(-1000, 1000, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, CFrame.new(10, 20, 30))
                ch.cursor = 0
                c.write(ch, CFrame.new(10.5, 20, 30))
                -- 1 header + at least 1 byte for X diff (Y/Z unchanged → no bytes)
                expect(ch.cursor):toBeLessThan(8)
                expect(ch.cursor):toBeGreaterThan(1)
            end)
            it("full pose change: 1 + 3 zints + 4 quat", function(): ()
                local c = Lync.deltaCFrame(-1000, 1000, 0.01)
                local ch = InternalChannel.create()
                c.write(ch, CFrame.new(10, 20, 30))
                ch.cursor = 0
                c.write(ch, CFrame.new(11, 21, 31) * CFrame.Angles(1, 0, 0))
                expect(ch.cursor):toBeGreaterThan(4)
            end)
        end)

        describe("round-trip", function(): ()
            it("identity CFrame survives", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                local r = roundTripDelta(c, ch, CFrame.identity)
                expect(math.abs(r.Position.X) < 0.02):toBe(true)
            end)
            it("position decode within precision", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                local r = roundTripDelta(c, ch, CFrame.new(5, 10, 15))
                expect(math.abs(r.Position.X - 5) < 0.02):toBe(true)
                expect(math.abs(r.Position.Y - 10) < 0.02):toBe(true)
                expect(math.abs(r.Position.Z - 15) < 0.02):toBe(true)
            end)
            it("rotation decode preserves orientation roughly", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                local original = CFrame.new(0, 0, 0) * CFrame.Angles(0, math.pi / 2, 0)
                local r = roundTripDelta(c, ch, original)
                local lookOriginal = original.LookVector
                local lookDecoded = r.LookVector
                expect(math.abs(lookOriginal.X - lookDecoded.X) < 0.01):toBe(true)
                expect(math.abs(lookOriginal.Z - lookDecoded.Z) < 0.01):toBe(true)
            end)
            it("position-only update preserves rotation", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                local rot = CFrame.Angles(0, math.pi / 4, 0)
                roundTripDelta(c, ch, CFrame.new(0, 0, 0) * rot)
                local r = roundTripDelta(c, ch, CFrame.new(5, 0, 0) * rot)
                local lookExpected = (CFrame.new(5, 0, 0) * rot).LookVector
                local lookDecoded = r.LookVector
                expect(math.abs(lookExpected.X - lookDecoded.X) < 0.02):toBe(true)
                expect(math.abs(lookExpected.Z - lookDecoded.Z) < 0.02):toBe(true)
            end)
        end)

        describe("define-time errors", function(): ()
            it("posMin >= posMax throws", function(): ()
                expect(function(): ()
                    Lync.deltaCFrame(10, 5, 0.01)
                end):toThrow("must be <")
            end)
            it("posMin == posMax throws", function(): ()
                expect(function(): ()
                    Lync.deltaCFrame(5, 5, 0.01)
                end):toThrow("must be <")
            end)
        end)

        describe("position range validation", function(): ()
            it("X above posMax throws", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, CFrame.new(101, 0, 0))
                end):toThrow("out of range")
            end)
            it("Y below posMin throws", function(): ()
                local c = Lync.deltaCFrame(-100, 100, 0.01)
                local ch = InternalChannel.create()
                expect(function(): ()
                    c.write(ch, CFrame.new(0, -101, 0))
                end):toThrow("out of range")
            end)
        end)
    end)

    describe("baseline cache integration", function(): ()
        it("UNCHANGED-style 1-byte writes after first frame are read-side stable", function(): ()
            local c = Lync.deltaInt(0, 1000)
            local ch = InternalChannel.create()
            local v1 = roundTripDelta(c, ch, 100)
            local v2 = roundTripDelta(c, ch, 100)
            expect(v1):toBe(100)
            expect(v2):toBe(100)
        end)
        it("Baseline.reset clears decoded state between sessions", function(): ()
            local c = Lync.deltaInt(0, 1000)
            local ch = InternalChannel.create()
            roundTripDelta(c, ch, 500)
            Baseline.reset()
            -- After reset, the read side has no baseline, so a fresh
            -- session that starts with a small diff treats prev as `min`.
            local ch2 = InternalChannel.create()
            local r = roundTripDelta(c, ch2, 0)
            expect(r):toBe(0)
        end)
    end)
end)

return nil
