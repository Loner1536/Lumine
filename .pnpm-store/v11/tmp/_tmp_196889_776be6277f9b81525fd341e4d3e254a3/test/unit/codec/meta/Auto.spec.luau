--!strict
--!optimize 2
-- Lync.auto: self-describing codec with u8 type tag.

local Env = require(script:FindFirstAncestor("test").Env)

local Lync = Env.Lync
local Channel = Env.Channel
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

describe("codec.meta.Auto", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("nil", function(): ()
        it("encodes to 1 byte", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, nil)
            expect(r):toBeNil()
            expect(w):toBe(1)
        end)
    end)

    describe("booleans", function(): ()
        it("true = 2 bytes", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, true)
            expect(r):toBe(true)
            expect(w):toBe(2)
        end)
        it("false = 2 bytes", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, false)
            expect(r):toBe(false)
            expect(w):toBe(2)
        end)
    end)

    describe("integer wire-type selection", function(): ()
        it("0 = u8 (2 bytes)", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 0)
            expect(w):toBe(2)
        end)
        it("255 = u8 (2 bytes)", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 255)
            expect(w):toBe(2)
        end)
        it("256 = u16 (3 bytes)", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 256)
            expect(w):toBe(3)
        end)
        it("65535 = u16 (3 bytes)", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 65535)
            expect(w):toBe(3)
        end)
        it("65536 = u32 (5 bytes)", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 65536)
            expect(w):toBe(5)
        end)
        it("-1 = i8 (2 bytes)", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, -1)
            expect(r):toBe(-1)
            expect(w):toBe(2)
        end)
        it("-128 = i8", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, -128)
            expect(w):toBe(2)
        end)
        it("-129 = i16", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, -129)
            expect(r):toBe(-129)
            expect(w):toBe(3)
        end)
        it("-32768 = i16", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, -32768)
            expect(w):toBe(3)
        end)
        it("-32769 = i32 (5 bytes)", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, -32769)
            expect(r):toBe(-32769)
            expect(w):toBe(5)
        end)
    end)

    describe("floats", function(): ()
        it("f32-representable = 5 bytes", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, 1.5)
            expect(r):toBeCloseTo(1.5)
            expect(w):toBe(5)
        end)
        it("requires f64 = 9 bytes", function(): ()
            local r, w = Channel.roundTripStrict(Lync.auto, math.pi)
            expect(r):toBeCloseTo(math.pi, 1e-14)
            expect(w):toBe(9)
        end)
        it("NaN takes the f64 path", function(): ()
            local _, w = Channel.roundTripStrict(Lync.auto, 0 / 0)
            expect(w):toBe(9)
        end)
    end)

    describe("strings", function(): ()
        it("empty", function(): ()
            expect(Channel.roundTripStrict(Lync.auto, "")):toBe("")
        end)
        it("short", function(): ()
            expect(Channel.roundTripStrict(Lync.auto, "hello")):toBe("hello")
        end)
        it("long (>191) uses varint length", function(): ()
            local s = string.rep("x", 300)
            expect(Channel.roundTripStrict(Lync.auto, s)):toBe(s)
        end)
    end)

    describe("Roblox datatypes", function(): ()
        it("Vector2", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Vector2.new(1, 2))
            expect(r.X):toBeCloseTo(1)
            expect(r.Y):toBeCloseTo(2)
        end)
        it("Vector3", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Vector3.new(1, 2, 3))
            expect(r.X):toBeCloseTo(1)
            expect(r.Z):toBeCloseTo(3)
        end)
        it("Color3", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Color3.fromRGB(255, 128, 0))
            expect(r.R):toBeCloseTo(1, 0.01)
        end)
        it("CFrame", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, CFrame.new(10, 20, 30))
            expect(r.Position.X):toBeCloseTo(10)
        end)
        it("UDim", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, UDim.new(0.5, 10))
            expect(r.Scale):toBeCloseTo(0.5)
        end)
        it("UDim2", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, UDim2.new(UDim.new(1, 0), UDim.new(0, 50)))
            expect(r.X.Scale):toBeCloseTo(1)
        end)
        it("NumberRange", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, NumberRange.new(5, 10))
            expect(r.Min):toBeCloseTo(5)
        end)
        it("Rect", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Rect.new(0, 0, 100, 100))
            expect(r.Max.X):toBeCloseTo(100)
        end)
        it("Ray", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Ray.new(Vector3.zero, Vector3.yAxis))
            expect(r.Direction.Y):toBeCloseTo(1)
        end)
        it("Vector2int16", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Vector2int16.new(10, -20))
            expect(r.X):toBe(10)
            expect(r.Y):toBe(-20)
        end)
        it("Vector3int16", function(): ()
            local r = Channel.roundTripStrict(Lync.auto, Vector3int16.new(1, 2, 3))
            expect(r.Z):toBe(3)
        end)
        it("buffer", function(): ()
            local input = buffer.create(4)
            buffer.writeu32(input, 0, 0xCAFE)
            local r = Channel.roundTripStrict(Lync.auto, input)
            expect(buffer.readu32(r, 0)):toBe(0xCAFE)
        end)
    end)

    describe("unsupported types", function(): ()
        it("plain table throws", function(): ()
            expect(function(): ()
                Channel.encode(Lync.auto, { 1, 2, 3 })
            end):toThrow("unsupported")
        end)
    end)
end)

return nil
