--!strict
--!optimize 2
-- Lync.cframe: lossless 24 bytes plus __call compressed 16 bytes (smallest-three quat).

local Env = require(script:FindFirstAncestor("test").Env)

local Lync = Env.Lync
local Channel = Env.Channel
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

describe("codec.datatype.CFrame", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("lossless metadata", function(): ()
        it("_size = 24", function(): ()
            expect((Lync.cframe :: any)._size):toBe(24)
        end)
        it("_typeCheck = CFrame", function(): ()
            expect((Lync.cframe :: any)._typeCheck):toBe("CFrame")
        end)
        it("has _directWrite/_directRead", function(): ()
            expect((Lync.cframe :: any)._directWrite):toBeType("function")
            expect((Lync.cframe :: any)._directRead):toBeType("function")
        end)
    end)

    describe("lossless round-trip", function(): ()
        it("identity", function(): ()
            local r = Channel.roundTripStrict(Lync.cframe, CFrame.new())
            expect(r.Position.X):toBeCloseTo(0)
            expect(r.Position.Y):toBeCloseTo(0)
            expect(r.Position.Z):toBeCloseTo(0)
        end)
        it("position only", function(): ()
            local r = Channel.roundTripStrict(Lync.cframe, CFrame.new(10, 20, 30))
            expect(r.Position.X):toBeCloseTo(10)
            expect(r.Position.Y):toBeCloseTo(20)
            expect(r.Position.Z):toBeCloseTo(30)
        end)
        it("position + rotation preserves both", function(): ()
            local cf = CFrame.new(10, 20, 30) * CFrame.Angles(0.5, 1.0, 0.3)
            local r = Channel.roundTripStrict(Lync.cframe, cf)
            expect(r.Position.X):toBeCloseTo(10, 1e-3)
            local rx, ry, rz = r:ToEulerAnglesXYZ()
            local ox, oy, oz = cf:ToEulerAnglesXYZ()
            expect(rx):toBeCloseTo(ox, 1e-3)
            expect(ry):toBeCloseTo(oy, 1e-3)
            expect(rz):toBeCloseTo(oz, 1e-3)
        end)
        it("90 degree rotation", function(): ()
            local cf = CFrame.Angles(math.pi / 2, 0, 0)
            local r = Channel.roundTripStrict(Lync.cframe, cf)
            local rx = r:ToEulerAnglesXYZ()
            expect(rx):toBeCloseTo(math.pi / 2, 1e-3)
        end)
        it("wire = 24 bytes", function(): ()
            local _, w = Channel.roundTripStrict(Lync.cframe, CFrame.new(1, 2, 3))
            expect(w):toBe(24)
        end)
    end)

    describe("compressed via __call", function(): ()
        it("_size = 16", function(): ()
            expect((Lync.cframe() :: any)._size):toBe(16)
        end)
        it("saves 8 bytes vs lossless", function(): ()
            local diff = (Lync.cframe :: any)._size - (Lync.cframe() :: any)._size
            expect(diff):toBe(8)
        end)
        it("rotation precision under ~0.005 rad", function(): ()
            local cf = CFrame.Angles(1.0, 0.5, 0.3)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            local ox, oy, oz = cf:ToEulerAnglesXYZ()
            local rx, ry, rz = r:ToEulerAnglesXYZ()
            expect(rx):toBeCloseTo(ox, 0.005)
            expect(ry):toBeCloseTo(oy, 0.005)
            expect(rz):toBeCloseTo(oz, 0.005)
        end)
        it("X-dominant quaternion", function(): ()
            local cf = CFrame.new(1, 2, 3) * CFrame.Angles(2.5, 0, 0)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            expect(r.Position.X):toBeCloseTo(1, 1e-3)
        end)
        it("Y-dominant quaternion", function(): ()
            local cf = CFrame.new(1, 2, 3) * CFrame.Angles(0, 2.5, 0)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            expect(r.Position.X):toBeCloseTo(1, 1e-3)
        end)
        it("Z-dominant quaternion", function(): ()
            local cf = CFrame.new(1, 2, 3) * CFrame.Angles(0, 0, 2.5)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            expect(r.Position.X):toBeCloseTo(1, 1e-3)
        end)
        it("W-dominant near-identity", function(): ()
            local cf = CFrame.new(1, 2, 3) * CFrame.Angles(0.1, 0.1, 0.1)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            expect(r.Position.X):toBeCloseTo(1, 1e-3)
        end)
        it("negative rotation preserved", function(): ()
            local cf = CFrame.Angles(-1, -0.5, -0.3)
            local r = Channel.roundTripStrict(Lync.cframe(), cf)
            local ox = cf:ToEulerAnglesXYZ()
            local rx = r:ToEulerAnglesXYZ()
            expect(rx):toBeCloseTo(ox, 0.005)
        end)
        it("_typeCheck = CFrame", function(): ()
            expect((Lync.cframe() :: any)._typeCheck):toBe("CFrame")
        end)
    end)
end)

return nil
