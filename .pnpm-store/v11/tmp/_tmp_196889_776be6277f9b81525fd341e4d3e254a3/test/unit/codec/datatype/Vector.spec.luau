--!strict
--!optimize 2
-- Lync.vec2 / Lync.vec3 lossless and __call quantized variants.

local Env = require(script:FindFirstAncestor("test").Env)

local Lync = Env.Lync
local Channel = Env.Channel
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

describe("codec.datatype.Vector", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("vec2 lossless metadata", function(): ()
        it("_size = 8", function(): ()
            expect((Lync.vec2 :: any)._size):toBe(8)
        end)
        it("_typeCheck = Vector2", function(): ()
            expect((Lync.vec2 :: any)._typeCheck):toBe("Vector2")
        end)
        it("has _directWrite/_directRead", function(): ()
            expect((Lync.vec2 :: any)._directWrite):toBeType("function")
            expect((Lync.vec2 :: any)._directRead):toBeType("function")
        end)
    end)

    describe("vec2 lossless round-trip", function(): ()
        it("zero", function(): ()
            local r, w = Channel.roundTripStrict(Lync.vec2, Vector2.zero)
            expect(r.X):toBeCloseTo(0)
            expect(r.Y):toBeCloseTo(0)
            expect(w):toBe(8)
        end)
        it("(1.5, -3.25)", function(): ()
            local r = Channel.roundTripStrict(Lync.vec2, Vector2.new(1.5, -3.25))
            expect(r.X):toBeCloseTo(1.5)
            expect(r.Y):toBeCloseTo(-3.25)
        end)
        it("(10000, -10000) within f32 precision", function(): ()
            local r = Channel.roundTripStrict(Lync.vec2, Vector2.new(10000, -10000))
            expect(r.X):toBeCloseTo(10000)
            expect(r.Y):toBeCloseTo(-10000)
        end)
    end)

    describe("vec2 quantized via __call", function(): ()
        it("u8 per component when range fits 256 steps", function(): ()
            local c = Lync.vec2(0, 100, 1)
            expect((c :: any)._size):toBe(2)
            local r = Channel.roundTripStrict(c, Vector2.new(50, 75))
            expect(r.X):toBeCloseTo(50, 1)
            expect(r.Y):toBeCloseTo(75, 1)
        end)
        it("u16 per component when range needs more", function(): ()
            expect((Lync.vec2(-1000, 1000, 0.1) :: any)._size):toBe(4)
        end)
        it("clamps below min", function(): ()
            local c = Lync.vec2(0, 100, 1)
            local r = Channel.roundTripStrict(c, Vector2.new(-50, -100))
            expect(r.X):toBeCloseTo(0, 1)
            expect(r.Y):toBeCloseTo(0, 1)
        end)
        it("clamps above max", function(): ()
            local c = Lync.vec2(0, 100, 1)
            local r = Channel.roundTripStrict(c, Vector2.new(200, 500))
            expect(r.X):toBeCloseTo(100, 1)
            expect(r.Y):toBeCloseTo(100, 1)
        end)
        it("min == max yields a constant codec (zero bytes)", function(): ()
            local c = Lync.vec2(5, 5, 1)
            local _, w = Channel.roundTripStrict(c, Vector2.new(123, 456))
            expect(w):toBe(0)
        end)
    end)

    describe("vec3 lossless metadata", function(): ()
        it("_size = 12", function(): ()
            expect((Lync.vec3 :: any)._size):toBe(12)
        end)
        it("_typeCheck = Vector3", function(): ()
            expect((Lync.vec3 :: any)._typeCheck):toBe("Vector3")
        end)
    end)

    describe("vec3 lossless round-trip", function(): ()
        it("(1, 2, 3)", function(): ()
            local r = Channel.roundTripStrict(Lync.vec3, Vector3.new(1, 2, 3))
            expect(r.X):toBeCloseTo(1)
            expect(r.Y):toBeCloseTo(2)
            expect(r.Z):toBeCloseTo(3)
        end)
        it("zero", function(): ()
            local r = Channel.roundTripStrict(Lync.vec3, Vector3.zero)
            expect(r.X):toBe(0)
            expect(r.Y):toBe(0)
            expect(r.Z):toBe(0)
        end)
        it("negative components", function(): ()
            local r = Channel.roundTripStrict(Lync.vec3, Vector3.new(-5, -10, -15))
            expect(r.X):toBeCloseTo(-5)
            expect(r.Y):toBeCloseTo(-10)
            expect(r.Z):toBeCloseTo(-15)
        end)
    end)

    describe("vec3 quantized via __call", function(): ()
        it("u8 per component = 3 bytes", function(): ()
            local c = Lync.vec3(0, 100, 1)
            expect((c :: any)._size):toBe(3)
            local r = Channel.roundTripStrict(c, Vector3.new(25, 50, 75))
            expect(r.X):toBeCloseTo(25, 1)
            expect(r.Z):toBeCloseTo(75, 1)
        end)
        it("u16 per component = 6 bytes", function(): ()
            expect((Lync.vec3(-1000, 1000, 0.1) :: any)._size):toBe(6)
        end)
        it("negative range round-trip", function(): ()
            local c = Lync.vec3(-100, 100, 1)
            local r = Channel.roundTripStrict(c, Vector3.new(-50, 0, 50))
            expect(r.X):toBeCloseTo(-50, 1)
            expect(r.Y):toBeCloseTo(0, 1)
            expect(r.Z):toBeCloseTo(50, 1)
        end)
    end)

    describe("define-time errors", function(): ()
        it("vec2 min > max throws", function(): ()
            expect(function(): ()
                Lync.vec2(10, 5, 1)
            end):toThrow("min")
        end)
        it("vec2 zero precision throws", function(): ()
            expect(function(): ()
                Lync.vec2(0, 100, 0)
            end):toThrow("precision")
        end)
        it("vec3 negative precision throws", function(): ()
            expect(function(): ()
                Lync.vec3(0, 100, -1)
            end):toThrow("precision")
        end)
    end)
end)

return nil
