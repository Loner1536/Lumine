--!strict
--!optimize 2
-- Lync.optional: 1-byte present/absent flag plus inner payload.

local Env = require(script:FindFirstAncestor("test").Env)

local Lync = Env.Lync
local Channel = Env.Channel
local Sandbox = Env.Sandbox

local describe = Env.describe
local it = Env.it
local expect = Env.expect
local beforeEach = Env.beforeEach

describe("codec.composite.Optional", function(): ()
    beforeEach(Sandbox.resetAll)

    describe("metadata", function(): ()
        it("flags _isOptional", function(): ()
            local c = Lync.optional(Lync.int(0, 255))
            expect((c :: any)._isOptional):toBe(true)
        end)
        it("references the inner codec via _inner", function(): ()
            local inner = Lync.int(0, 255)
            local c = Lync.optional(inner)
            expect((c :: any)._inner):toBe(inner)
        end)
        it("_hasUnknown propagates from inner", function(): ()
            local c = Lync.optional(Lync.unknown)
            expect((c :: any)._hasUnknown):toBe(true)
        end)
        it("_hasUnknown is nil when inner has no unknown", function(): ()
            local c = Lync.optional(Lync.int(0, 255))
            expect((c :: any)._hasUnknown):toBeNil()
        end)
    end)

    describe("nil case", function(): ()
        it("encodes to a single 0x00 byte", function(): ()
            local r = Channel.encode(Lync.optional(Lync.int(0, 255)), nil)
            expect(r.length):toBe(1)
            expect(r.buffer):toMatchBuffer({ 0x00 })
        end)
        it("decodes back to nil", function(): ()
            local v = Channel.roundTripStrict(Lync.optional(Lync.int(0, 255)), nil)
            expect(v):toBeNil()
        end)
    end)

    describe("present case", function(): ()
        it("encodes a u8 with flag prefix (2 bytes total)", function(): ()
            local r = Channel.encode(Lync.optional(Lync.int(0, 255)), 42)
            expect(r.length):toBe(2)
            expect(r.buffer):toMatchBuffer({ 0x01, 0x2A })
        end)
        it("present zero is distinct from nil", function(): ()
            local r = Channel.encode(Lync.optional(Lync.int(0, 255)), 0)
            expect(r.length):toBe(2)
            expect(r.buffer):toMatchBuffer({ 0x01, 0x00 })
            local v = Channel.decode(Lync.optional(Lync.int(0, 255)), r)
            expect(v):toBe(0)
        end)
        it("present false bool is distinct from nil", function(): ()
            local c = Lync.optional(Lync.bool)
            local r = Channel.encode(c, false)
            expect(r.length):toBe(2)
            local v = Channel.decode(c, r)
            expect(v):toBe(false)
        end)
        it("optional string round-trips", function(): ()
            expect(Channel.roundTripStrict(Lync.optional(Lync.string), "hi")):toBe("hi")
        end)
        it("optional struct round-trips", function(): ()
            local c = Lync.optional(Lync.struct({ x = Lync.int(0, 255) }))
            local v = Channel.roundTripStrict(c, { x = 42 })
            expect(v.x):toBe(42)
        end)
    end)

    describe("nested optional", function(): ()
        it("optional of optional handles three states", function(): ()
            local c = Lync.optional(Lync.optional(Lync.int(0, 255)))
            expect(Channel.roundTripStrict(c, nil)):toBeNil()
            expect(Channel.roundTripStrict(c, 42)):toBe(42)
        end)
        it("optional of optional present writes 2 flag bytes + 1 data", function(): ()
            local c = Lync.optional(Lync.optional(Lync.int(0, 255)))
            local r = Channel.encode(c, 99)
            expect(r.length):toBe(3)
            expect(buffer.readu8(r.buffer, 0)):toBe(1)
            expect(buffer.readu8(r.buffer, 1)):toBe(1)
            expect(buffer.readu8(r.buffer, 2)):toBe(99)
        end)
        it("triple-nested optional", function(): ()
            local c = Lync.optional(Lync.optional(Lync.optional(Lync.bool)))
            expect(Channel.roundTripStrict(c, nil)):toBeNil()
            expect(Channel.roundTripStrict(c, true)):toBe(true)
            expect(Channel.roundTripStrict(c, false)):toBe(false)
        end)
    end)

    describe("optional containers", function(): ()
        it("optional of array round-trips empty array", function(): ()
            local c = Lync.optional(Lync.array(Lync.int(0, 255)))
            local r = Channel.roundTripStrict(c, {})
            expect(#r):toBe(0)
        end)
        it("optional of array nil is distinct from optional empty array", function(): ()
            local c = Lync.optional(Lync.array(Lync.int(0, 255)))
            local nilEnc = Channel.encode(c, nil)
            local emptyEnc = Channel.encode(c, {})
            expect(nilEnc.length < emptyEnc.length):toBe(true)
        end)
        it("optional of map round-trips", function(): ()
            local c = Lync.optional(Lync.map(Lync.string, Lync.int(0, 255)))
            local r = Channel.roundTripStrict(c, { a = 1, b = 2 })
            expect(r.a):toBe(1)
            expect(r.b):toBe(2)
        end)
        it("optional of tagged round-trips", function(): ()
            local tagged = Lync.tagged("kind", { x = Lync.struct({ v = Lync.int(0, 255) }) })
            local c = Lync.optional(tagged)
            local r = Channel.roundTripStrict(c, { kind = "x", v = 42 })
            expect(r.v):toBe(42)
        end)
    end)

    describe("presence byte boundary", function(): ()
        it("read at position past buffer end throws", function(): ()
            local c = Lync.optional(Lync.int(0, 255))
            local empty = buffer.create(0)
            expect(function(): ()
                c.read(empty, 0, nil)
            end):toThrow()
        end)
        it("read of buffer = {0x00} returns nil consuming 1 byte", function(): ()
            local c = Lync.optional(Lync.int(0, 255))
            local b = buffer.create(1)
            buffer.writeu8(b, 0, 0)
            local v, consumed = c.read(b, 0, nil)
            expect(v):toBeNil()
            expect(consumed):toBe(1)
        end)
        it("read of buffer = {0x01, 42} returns 42 consuming 2 bytes", function(): ()
            local c = Lync.optional(Lync.int(0, 255))
            local b = buffer.create(2)
            buffer.writeu8(b, 0, 1)
            buffer.writeu8(b, 1, 42)
            local v, consumed = c.read(b, 0, nil)
            expect(v):toBe(42)
            expect(consumed):toBe(2)
        end)
    end)
end)

return nil
